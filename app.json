{
  "expo": {
    "name": "歧途",
    "slug": "videos-cms",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4f1ea"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.videoscms"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#f4f1ea"
      },
      "permissions": [],
      "package": "com.anonymous.videoscms"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-video"
    ]
  }
}
